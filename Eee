-- Optimization and Rendering Configuration
local function cleanEnvironment()
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9000000000
    Lighting.Brightness = 1
    Lighting.EnvironmentDiffuseScale = 0
    Lighting.EnvironmentSpecularScale = 0
    
    for _, descendant in pairs(workspace:GetDescendants()) do
        if descendant:IsA("BasePart") then
            descendant.Material = Enum.Material.Plastic
            descendant.Reflectance = 0
            descendant.CastShadow = false
        end
    end
end

-- Accessory Purge Control
local function removeAccessories(character)
    for _, obj in pairs(character:GetDescendants()) do
        if obj:IsA("Accessory") or obj.Name:find("Hair") or obj.Name:find("Glasses") or obj.Name:find("Hat") then
            obj:Destroy()
        end
    end
end

-- Player Initialization Triggers
local localPlayer = Players.LocalPlayer

local function setupPlayerHandlers(player)
    player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        addBillboardGuis(char)
        removeAccessories(char)
        
        for _, limb in pairs(char:GetChildren()) do
            if limb:IsA("BasePart") then
                limb.CanCollide = false
            end
        end
    end)
    if player.Character then
        addBillboardGuis(player.Character)
        removeAccessories(player.Character)
    end
end

for _, player in pairs(Players:GetPlayers()) do
    if player ~= localPlayer then
        setupPlayerHandlers(player)
    end
end
Players.PlayerAdded:Connect(setupPlayerHandlers)

-- Primary Velocity Modification Run Loop
RunService.RenderStepped:Connect(function()
    local character = localPlayer.Character
    if character and character:FindFirstChild("HumanoidRootPart") and character:FindFirstChild("Humanoid") then
        local root = character.HumanoidRootPart
        local hum = character.Humanoid
        
        if hum.MoveDirection.Magnitude > 0 then
            local configuredSpeed = tonumber(normalSpeedBox.Text) or 60
            local targetVelocity = hum.MoveDirection * configuredSpeed
            root.Velocity = Vector3.new(targetVelocity.X, root.Velocity.Y, targetVelocity.Z)
        end
    end
end)

